{
  "expo": {
    "name": "Jobify",
    "slug": "jobify-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#2d2d2d",
    "splash": {
      "backgroundColor": "#2d2d2d",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.jobify.mobile"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
