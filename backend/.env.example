# ─────────────────────────────────────────────────────────────────────────────
# Jobify Backend — environment variables
# Copy this file to `.env` and fill in real values.
#
# WHERE THESE ARE USED:
#  • Render  → Dashboard → your service → Environment → "Add from .env" (paste this)
#  • Local   → Spring Boot does NOT auto-read .env. Either set these as OS env vars,
#              or just leave them unset and the app uses the dev fallbacks in
#              application.properties (local MongoDB, no email).
# Never commit the filled-in .env (it's gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string. Keep the database name `jobportal` before the `?`.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/jobportal?retryWrites=true&w=majority
SPRING_DATA_MONGODB_URI=mongodb+srv://ritiksharma555598_db_user:8qSowQEvEbKu9N2x@jobportal.py17oru.mongodb.net/jobportal?retryWrites=true&w=majority

# Gmail used to send OTP emails.
MAIL_USERNAME=chandrabhan.work@gmail.com
# Gmail APP PASSWORD (16 chars, no spaces) — NOT your normal Google password.
# Create at: Google Account → Security → App passwords.
MAIL_PASSWORD=zystqrsphtmttgfg

# Secret used to sign JWTs. Use a long random string (64+ chars).
# On Render the blueprint can auto-generate this (generateValue: true).
JWT_SECRET=afafasfafafasfasfasfafacasdasfasxASFACASDFACASDFASFASFDAFASFASDAADSCSDFADCVSGCFVADXCcadwavfsfarvf

# Optional — usually leave unset.
# PORT is provided automatically by Render. Set it locally only to override 8080.
# PORT=8080
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
